{
  "name": "@unconfig/eslint-config",
  "version": "0.1.11",
  "description": "🚀 The package offer eslint-config for @unconfig!",
  "type": "module",
  "keywords": [
    "unconfig",
    "monorepo",
    "pnpm",
    "turborepo",
    "changesets",
    "eslint",
    "eslint-config"
  ],
  "license": "MIT",
  "homepage": "https://github.com/i7eo/unconfig/blob/master/packages/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/i7eo/unconfig/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/i7eo/unconfig.git",
    "directory": "packages/eslint-config"
  },
  "author": "i7eo <admin@i7eo.com> (https://github.com/i7eo)",
  "files": [
    "dist"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "DEV=true pnpm build",
    "test": "vitest",
    "lint": "run-s \"lint:**\"",
    "lint:prettier": "prettier . --write",
    "clean": "run-s \"clean:**\"",
    "clean:cache": "rimraf .turbo && rimraf dist",
    "clean:deps": "rimraf node_modules"
  },
  "peerDependencies": {
    "eslint": "^10.6.0"
  },
  "dependencies": {
    "@eslint/compat": "^2.1.0",
    "@unconfig/utils": "workspace:*",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-define-config": "^2.1.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-markdownlint": "^0.10.1",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unicorn": "^69.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-yml": "^3.5.0",
    "globals": "^17.7.0",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.62.1",
    "vue-eslint-parser": "^10.4.1",
    "yaml-eslint-parser": "^2.0.0"
  },
  "devDependencies": {
    "@unconfig/prettier-config": "workspace:*",
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9.15.9"
  }
}
