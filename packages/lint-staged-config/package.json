{
  "name": "@unconfig/lint-staged-config",
  "version": "0.1.10",
  "description": "🚀 The package offer lint-staged-config for @unconfig!",
  "type": "module",
  "keywords": [
    "unconfig",
    "monorepo",
    "pnpm",
    "turborepo",
    "changesets",
    "lint-staged",
    "lint-staged-config"
  ],
  "license": "MIT",
  "homepage": "https://github.com/i7eo/unconfig/blob/master/packages/lint-staged-config#readme",
  "bugs": {
    "url": "https://github.com/i7eo/unconfig/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/i7eo/unconfig.git",
    "directory": "packages/lint-staged-config"
  },
  "author": "i7eo <admin@i7eo.com> (https://github.com/i7eo)",
  "files": [
    "dist"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "DEV=true pnpm build",
    "test": "vitest",
    "lint": "run-s \"lint:**\"",
    "lint:prettier": "prettier . --write",
    "clean": "run-s \"clean:**\"",
    "clean:cache": "rimraf .turbo && rimraf dist",
    "clean:deps": "rimraf node_modules"
  },
  "peerDependencies": {
    "lint-staged": "^17.0.8"
  },
  "dependencies": {
    "@types/lint-staged": "^14.0.0",
    "@unconfig/utils": "workspace:*",
    "lint-staged": "^17.0.8"
  },
  "devDependencies": {
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  }
}
