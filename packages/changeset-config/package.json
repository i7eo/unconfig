{
  "name": "@unconfig/changeset-config",
  "version": "0.1.11",
  "description": "🚀 The package offer changeset-config for @unconfig!",
  "type": "module",
  "keywords": [
    "unconfig",
    "monorepo",
    "pnpm",
    "turborepo",
    "changesets",
    "changeset",
    "changeset-config"
  ],
  "license": "MIT",
  "homepage": "https://github.com/i7eo/unconfig/blob/master/packages/changeset-config#readme",
  "bugs": {
    "url": "https://github.com/i7eo/unconfig/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/i7eo/unconfig.git",
    "directory": "packages/changeset-config"
  },
  "author": "i7eo <admin@i7eo.com> (https://github.com/i7eo)",
  "files": [
    "dist"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "DEV=true pnpm build",
    "test": "vitest",
    "lint": "run-s \"lint:**\"",
    "lint:prettier": "prettier . --write",
    "clean": "run-s \"clean:**\"",
    "clean:cache": "rimraf .turbo && rimraf dist",
    "clean:deps": "rimraf node_modules"
  },
  "peerDependencies": {
    "@changesets/cli": "^2.31.0"
  },
  "dependencies": {
    "@changesets/assemble-release-plan": "^6.0.10",
    "@changesets/cli": "^2.31.0",
    "@changesets/config": "^3.1.4",
    "@changesets/pre": "^2.0.2",
    "@changesets/read": "^0.6.7",
    "@changesets/types": "^6.1.0",
    "@manypkg/get-packages": "^3.1.0",
    "@octokit/core": "^7.0.6",
    "@types/inquirer": "^9.0.10",
    "@types/semver": "^7.7.1",
    "@unconfig/meta": "workspace:*",
    "changesets-format-with-issue-links": "^0.3.0",
    "inquirer": "^14.0.2",
    "prettier": "^3.9.4",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9.15.9"
  }
}
