{
  "name": "@unconfig/github",
  "version": "0.1.11",
  "description": "🚀 The package offer github for unconfig!",
  "type": "module",
  "keywords": [
    "monorepo",
    "pnpm",
    "turborepo",
    "changesets",
    "vite",
    "vue",
    "github"
  ],
  "license": "MIT",
  "author": "i7eo",
  "files": [
    "dist"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "require": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./contributor.json": "./dist/contributor.json",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./contributor.json": "./dist/contributor.json",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build:contributor": "tsx ./src/contributor.ts",
    "build": "tsdown && pnpm build:contributor",
    "dev": "DEV=true pnpm build",
    "test": "vitest",
    "lint": "run-s \"lint:**\"",
    "lint:eslint": "TIMING=1 eslint \"*.{js,jsx,ts,tsx,md,json,jsonc}\" --fix",
    "lint:prettier": "prettier --write \"*.{js,ts,jsx,tsx,md,json,jsonc}\"",
    "clean": "run-p \"clean:**\"",
    "clean:cache": "rimraf .turbo && rimraf dist",
    "clean:deps": "rimraf node_modules"
  },
  "dependencies": {
    "@octokit/core": "^7.0.6",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^26.0.1",
    "@unconfig/meta": "workspace:*",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "npm-run-all2": "^9.0.2",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  }
}
